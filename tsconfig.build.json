{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rewriteRelativeImportExtensions": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "src/**/*.ts",
    "web/**/*.ts"
  ],
  "exclude": [
    "tests/**",
    "node_modules",
    "prototypes",
    "target",
    "crates",
    "dist",
    "reports",
    ".stryker-tmp"
  ]
}
