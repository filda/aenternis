{
  "name": "aenternis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aenternis - 3D toroidální simulace s programovatelnými entitami jako 8bit mikropočítači",
  "scripts": {
    "dev": "vite",
    "dev:p8": "vite --open /prototypes/08-viewer-3d/",
    "preview": "vite preview",
    "build": "bash ./build",
    "build:ts": "tsc -p tsconfig.build.json",
    "check": "bash ./check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.6",
    "happy-dom": "^20.9.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.5"
  }
}
